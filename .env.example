# ---- Core ----
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# ---- Database ----
# Production (Vercel): Postgres — e.g. Vercel Postgres / Neon / Supabase.
# The schema uses the postgresql provider by default.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Local dev tip: you can either run a local postgres, or temporarily switch
# `datasource db { provider = "sqlite" }` in prisma/schema.prisma and use
# DATABASE_URL="file:./dev.db" for zero-setup local work.

# ---- OAuth (optional but recommended) ----
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Price IDs for the two plans shown on /pricing
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_xxx

# ---- OpenAI ----
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Lumen AI"
