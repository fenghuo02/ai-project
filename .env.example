# ---- Core ----
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# ---- Database ----
# Local dev: sqlite (ready out of the box)
DATABASE_URL="file:./dev.db"
# Production (Vercel): use Postgres, e.g. Neon / Supabase / Vercel Postgres
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ---- OAuth (optional but recommended) ----
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Price IDs for the two plans shown on /pricing
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_xxx

# ---- OpenAI ----
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Lumen AI"
