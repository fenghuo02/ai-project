//@version=5
// =============================================================================
//  XAUUSD 多周期共振仪表盘 (Multi-Timeframe Dashboard)
//  在图表右上角显示 M15 / H1 / H4 / D1 / W1 五个周期的：
//    - 趋势方向 (EMA 排列)
//    - RSI 状态
//    - MACD 动能
//    - 综合评分 (0-10)
//  作者：xauusd-trading-system
// =============================================================================
indicator("XAUUSD MTF Dashboard", shorttitle="XAU MTF", overlay=true)

// ---------- 1. 输入 ----------
grpStyle = "面板样式"
panelPos = input.string("top_right", "面板位置", options=["top_right", "top_left", "bottom_right", "bottom_left", "middle_right"], group=grpStyle)
textSize = input.string("normal", "字体大小", options=["tiny", "small", "normal", "large"], group=grpStyle)

grpEMA = "EMA 长度"
emaShortLen = input.int(20,  "EMA 短", group=grpEMA)
emaMidLen   = input.int(50,  "EMA 中", group=grpEMA)
emaLongLen  = input.int(200, "EMA 长", group=grpEMA)

grpRSI = "RSI"
rsiLen = input.int(14, "RSI 长度", group=grpRSI)
rsiOB  = input.int(70, "超买", group=grpRSI)
rsiOS  = input.int(30, "超卖", group=grpRSI)

// ---------- 2. 工具函数 ----------
f_pos(s) =>
    s == "top_right"     ? position.top_right     :
     s == "top_left"      ? position.top_left      :
     s == "bottom_right"  ? position.bottom_right  :
     s == "bottom_left"   ? position.bottom_left   :
     position.middle_right

f_size(s) =>
    s == "tiny" ? size.tiny : s == "small" ? size.small : s == "large" ? size.large : size.normal

// 获取某个周期的趋势 / RSI / MACD 摘要
f_tfSummary(tf) =>
    [_close, _eS, _eM, _eL, _rsi, _macd, _signal, _hist] = request.security(syminfo.tickerid, tf,
        [close,
         ta.ema(close, emaShortLen),
         ta.ema(close, emaMidLen),
         ta.ema(close, emaLongLen),
         ta.rsi(close, rsiLen),
         ta.macd(close, 12, 26, 9)],
         barmerge.gaps_off, barmerge.lookahead_off)
    bull = _close > _eM and _eS > _eM and _eM > _eL
    bear = _close < _eM and _eS < _eM and _eM < _eL
    trendStr = bull ? "多" : bear ? "空" : "震"
    trendCol = bull ? color.green : bear ? color.red : color.gray

    rsiStr = str.tostring(_rsi, "#.#")
    rsiCol = _rsi > rsiOB ? color.red : _rsi < rsiOS ? color.green : color.white

    macdBull = _macd > _signal and _hist > 0
    macdBear = _macd < _signal and _hist < 0
    macdStr = macdBull ? "多动" : macdBear ? "空动" : "弱"
    macdCol = macdBull ? color.green : macdBear ? color.red : color.gray

    // 评分：趋势 4 分 + RSI 2 分 + MACD 4 分
    score = 0
    score := score + (bull ? 4 : bear ? -4 : 0)
    score := score + (macdBull ? 4 : macdBear ? -4 : 0)
    score := score + (_rsi > 50 ? 2 : -2)
    [trendStr, trendCol, rsiStr, rsiCol, macdStr, macdCol, score, _close]

// ---------- 3. 各周期数据 ----------
[t15, c15, r15, rc15, m15s, mc15, s15, p15] = f_tfSummary("15")
[t60, c60, r60, rc60, m60s, mc60, s60, p60] = f_tfSummary("60")
[t240, c240, r240, rc240, m240s, mc240, s240, p240] = f_tfSummary("240")
[tD, cD, rD, rcD, mDs, mcD, sD, pD] = f_tfSummary("D")
[tW, cW, rW, rcW, mWs, mcW, sW, pW] = f_tfSummary("W")

totalScore = s15 + s60 + s240 + sD + sW       // 范围 -50 到 +50
normalizedScore = math.round(totalScore / 5.0) // 范围 -10 到 +10

// ---------- 4. 综合判定 ----------
overallStr   = normalizedScore >=  6 ? "强多" :
               normalizedScore >=  2 ? "偏多" :
               normalizedScore <= -6 ? "强空" :
               normalizedScore <= -2 ? "偏空" : "中性"
overallCol   = normalizedScore >=  6 ? color.lime :
               normalizedScore >=  2 ? color.green :
               normalizedScore <= -6 ? color.red :
               normalizedScore <= -2 ? color.maroon : color.yellow

// 共振判定：M15/H1/H4/D1 全部一致才算共振
allBull = c15 == cD and c60 == cD and c240 == cD and cD == cW
resonance = ""
resonanceCol = color.gray
if t15 == "多" and t60 == "多" and t240 == "多" and tD == "多"
    resonance := "✓ 多头共振"
    resonanceCol := color.lime
else if t15 == "空" and t60 == "空" and t240 == "空" and tD == "空"
    resonance := "✓ 空头共振"
    resonanceCol := color.red
else if (t15 == "多" or t60 == "多") and tD == "空"
    resonance := "✗ 反趋势 慎入"
    resonanceCol := color.orange
else if (t15 == "空" or t60 == "空") and tD == "多"
    resonance := "✗ 反趋势 慎入"
    resonanceCol := color.orange
else
    resonance := "— 无共振"
    resonanceCol := color.gray

// ---------- 5. 表格绘制 ----------
var table dash = table.new(f_pos(panelPos), 5, 9, border_width=1, frame_color=color.gray, frame_width=1)

if barstate.islast
    // 标题行
    table.cell(dash, 0, 0, "周期",  text_color=color.white, bgcolor=color.new(color.black, 20), text_size=f_size(textSize))
    table.cell(dash, 1, 0, "趋势",  text_color=color.white, bgcolor=color.new(color.black, 20), text_size=f_size(textSize))
    table.cell(dash, 2, 0, "RSI",   text_color=color.white, bgcolor=color.new(color.black, 20), text_size=f_size(textSize))
    table.cell(dash, 3, 0, "MACD",  text_color=color.white, bgcolor=color.new(color.black, 20), text_size=f_size(textSize))
    table.cell(dash, 4, 0, "分数",  text_color=color.white, bgcolor=color.new(color.black, 20), text_size=f_size(textSize))

    // M15
    table.cell(dash, 0, 1, "M15", text_color=color.white, text_size=f_size(textSize))
    table.cell(dash, 1, 1, t15,   text_color=c15,         text_size=f_size(textSize))
    table.cell(dash, 2, 1, r15,   text_color=rc15,        text_size=f_size(textSize))
    table.cell(dash, 3, 1, m15s,  text_color=mc15,        text_size=f_size(textSize))
    table.cell(dash, 4, 1, str.tostring(s15), text_color=s15>0?color.green:s15<0?color.red:color.gray, text_size=f_size(textSize))

    // H1
    table.cell(dash, 0, 2, "H1",  text_color=color.white, text_size=f_size(textSize))
    table.cell(dash, 1, 2, t60,   text_color=c60,         text_size=f_size(textSize))
    table.cell(dash, 2, 2, r60,   text_color=rc60,        text_size=f_size(textSize))
    table.cell(dash, 3, 2, m60s,  text_color=mc60,        text_size=f_size(textSize))
    table.cell(dash, 4, 2, str.tostring(s60), text_color=s60>0?color.green:s60<0?color.red:color.gray, text_size=f_size(textSize))

    // H4
    table.cell(dash, 0, 3, "H4",  text_color=color.white, text_size=f_size(textSize))
    table.cell(dash, 1, 3, t240,  text_color=c240,        text_size=f_size(textSize))
    table.cell(dash, 2, 3, r240,  text_color=rc240,       text_size=f_size(textSize))
    table.cell(dash, 3, 3, m240s, text_color=mc240,       text_size=f_size(textSize))
    table.cell(dash, 4, 3, str.tostring(s240), text_color=s240>0?color.green:s240<0?color.red:color.gray, text_size=f_size(textSize))

    // D1
    table.cell(dash, 0, 4, "D1",  text_color=color.white, text_size=f_size(textSize))
    table.cell(dash, 1, 4, tD,    text_color=cD,          text_size=f_size(textSize))
    table.cell(dash, 2, 4, rD,    text_color=rcD,         text_size=f_size(textSize))
    table.cell(dash, 3, 4, mDs,   text_color=mcD,         text_size=f_size(textSize))
    table.cell(dash, 4, 4, str.tostring(sD), text_color=sD>0?color.green:sD<0?color.red:color.gray, text_size=f_size(textSize))

    // W1
    table.cell(dash, 0, 5, "W1",  text_color=color.white, text_size=f_size(textSize))
    table.cell(dash, 1, 5, tW,    text_color=cW,          text_size=f_size(textSize))
    table.cell(dash, 2, 5, rW,    text_color=rcW,         text_size=f_size(textSize))
    table.cell(dash, 3, 5, mWs,   text_color=mcW,         text_size=f_size(textSize))
    table.cell(dash, 4, 5, str.tostring(sW), text_color=sW>0?color.green:sW<0?color.red:color.gray, text_size=f_size(textSize))

    // 综合分数行
    table.cell(dash, 0, 6, "综合", text_color=color.white, bgcolor=color.new(color.gray, 50), text_size=f_size(textSize))
    table.cell(dash, 1, 6, overallStr, text_color=overallCol, bgcolor=color.new(color.gray, 50), text_size=f_size(textSize))
    table.cell(dash, 2, 6, "", bgcolor=color.new(color.gray, 50))
    table.cell(dash, 3, 6, "", bgcolor=color.new(color.gray, 50))
    table.cell(dash, 4, 6, str.tostring(normalizedScore) + "/10", text_color=overallCol, bgcolor=color.new(color.gray, 50), text_size=f_size(textSize))

    // 共振行
    table.cell(dash, 0, 7, "共振", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=f_size(textSize))
    table.cell(dash, 1, 7, resonance, text_color=resonanceCol, bgcolor=color.new(color.black, 30), text_size=f_size(textSize))
    table.cell(dash, 2, 7, "", bgcolor=color.new(color.black, 30))
    table.cell(dash, 3, 7, "", bgcolor=color.new(color.black, 30))
    table.cell(dash, 4, 7, "", bgcolor=color.new(color.black, 30))

    // 操作建议行
    suggest = normalizedScore >= 6 ? "✓ 顺势做多 / 等回调" :
              normalizedScore >= 2 ? "偏多 谨慎入" :
              normalizedScore <=-6 ? "✓ 顺势做空 / 等反弹" :
              normalizedScore <=-2 ? "偏空 谨慎入" :
              "✗ 观望 不交易"
    table.cell(dash, 0, 8, "建议", text_color=color.white, bgcolor=color.new(color.navy, 30), text_size=f_size(textSize))
    table.cell(dash, 1, 8, suggest, text_color=overallCol, bgcolor=color.new(color.navy, 30), text_size=f_size(textSize))
    table.cell(dash, 2, 8, "", bgcolor=color.new(color.navy, 30))
    table.cell(dash, 3, 8, "", bgcolor=color.new(color.navy, 30))
    table.cell(dash, 4, 8, "", bgcolor=color.new(color.navy, 30))

// ---------- 6. 提醒 ----------
alertcondition(t15 == "多" and t60 == "多" and t240 == "多" and tD == "多", title="XAU 多周期多头共振", message="XAUUSD M15+H1+H4+D1 多头共振 {{ticker}} @ {{close}}")
alertcondition(t15 == "空" and t60 == "空" and t240 == "空" and tD == "空", title="XAU 多周期空头共振", message="XAUUSD M15+H1+H4+D1 空头共振 {{ticker}} @ {{close}}")
