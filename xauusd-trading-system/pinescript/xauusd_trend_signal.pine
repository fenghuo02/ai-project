//@version=5
// =============================================================================
//  XAUUSD 趋势信号指标 (Trend Signal)
//  与策略文档 strategy/trend_strategy.md 对应
//  核心：D1 + W1 EMA 共振 / MACD 动能 / 结构突破 (HH-HL / LH-LL) / 回调入场
//  作者：xauusd-trading-system
// =============================================================================
indicator("XAUUSD Trend Signal", shorttitle="XAU Trend", overlay=true, max_lines_count=300, max_labels_count=300)

// ---------- 1. 输入参数 ----------
grpEMA = "趋势 EMA"
emaShortLen = input.int(20,  "EMA 短期 (D1=20)", group=grpEMA)
emaMidLen   = input.int(50,  "EMA 中期 (D1=50)", group=grpEMA)
emaLongLen  = input.int(200, "EMA 长期 (D1=200)", group=grpEMA)

grpHTF = "高级别趋势确认"
htfTF       = input.timeframe("W", "周线确认时间框", group=grpHTF)
useWeekly   = input.bool(true, "启用 W1 趋势过滤", group=grpHTF)

grpMACD = "MACD 动能"
macdFast   = input.int(12, "MACD 快线", group=grpMACD)
macdSlow   = input.int(26, "MACD 慢线", group=grpMACD)
macdSignal = input.int(9,  "MACD 信号", group=grpMACD)

grpStruct = "结构判定"
swingLen   = input.int(5, "Swing 高低点回看 K 线数", minval=2, group=grpStruct)

grpATR = "ATR 与止损"
atrLen     = input.int(14,  "ATR 长度", group=grpATR)
atrSLMul   = input.float(1.5, "止损 ATR 倍数", step=0.1, group=grpATR)
atrTPMul1  = input.float(3.0, "T1 ATR 倍数 (1:2)", step=0.1, group=grpATR)
atrTPMul2  = input.float(5.0, "T2 ATR 倍数 (1:3.3)", step=0.1, group=grpATR)
atrTPMul3  = input.float(8.0, "T3 ATR 倍数 (1:5+)", step=0.1, group=grpATR)

grpFilter = "过度延伸过滤"
extMul     = input.float(3.0, "价格距 EMA200 超过 N×ATR 视为过度延伸（不入场）", step=0.5, group=grpFilter)

// ---------- 2. 主指标计算 ----------
emaShort = ta.ema(close, emaShortLen)
emaMid   = ta.ema(close, emaMidLen)
emaLong  = ta.ema(close, emaLongLen)

// 高级别（W1）EMA20 / EMA50
htfEma20 = request.security(syminfo.tickerid, htfTF, ta.ema(close, 20),  barmerge.gaps_off, barmerge.lookahead_off)
htfEma50 = request.security(syminfo.tickerid, htfTF, ta.ema(close, 50),  barmerge.gaps_off, barmerge.lookahead_off)
htfClose = request.security(syminfo.tickerid, htfTF, close,              barmerge.gaps_off, barmerge.lookahead_off)
htfBull  = htfClose > htfEma20 and htfEma20 > htfEma50
htfBear  = htfClose < htfEma20 and htfEma20 < htfEma50

// 当前周期趋势
trendBull = close > emaMid and emaShort > emaMid and emaMid > emaLong
trendBear = close < emaMid and emaShort < emaMid and emaMid < emaLong
trendOK_Long  = useWeekly ? (trendBull and htfBull) : trendBull
trendOK_Short = useWeekly ? (trendBear and htfBear) : trendBear

// MACD
[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSignal)
macdBull = macdLine > signalLine and histLine > 0 and histLine > histLine[1]
macdBear = macdLine < signalLine and histLine < 0 and histLine < histLine[1]

// ATR
atrVal = ta.atr(atrLen)

// 过度延伸
overExtendedBull = (close - emaLong) > extMul * atrVal
overExtendedBear = (emaLong - close) > extMul * atrVal

// ---------- 3. 结构判定 (HH/HL/LH/LL) ----------
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low,  swingLen, swingLen)

var float lastHigh   = na
var float prevHigh   = na
var float lastLow    = na
var float prevLow    = na

if not na(ph)
    prevHigh := lastHigh
    lastHigh := ph
if not na(pl)
    prevLow := lastLow
    lastLow := pl

isHH = not na(lastHigh) and not na(prevHigh) and lastHigh > prevHigh
isLH = not na(lastHigh) and not na(prevHigh) and lastHigh < prevHigh
isHL = not na(lastLow)  and not na(prevLow)  and lastLow  > prevLow
isLL = not na(lastLow)  and not na(prevLow)  and lastLow  < prevLow

structureBull = isHH and isHL
structureBear = isLH and isLL

// ---------- 4. 入场模型 ----------
// 模型 T1：回踩 EMA20 / EMA50
pullbackToEmaLong  = low  <= emaShort and low  >= emaMid and trendOK_Long
pullbackToEmaShort = high >= emaShort and high <= emaMid and trendOK_Short

// 入场触发：回踩 + 当根 K 线收回趋势侧 + MACD 动能配合
entryLong  = pullbackToEmaLong  and close > open and macdBull and not overExtendedBull and structureBull
entryShort = pullbackToEmaShort and close < open and macdBear and not overExtendedBear and structureBear

// 模型 T2：突破回测（突破前 swing 高/低 0.5 ATR 后回踩不破）
breakoutLong  = ta.crossover(close, prevHigh + atrVal*0.5)  and trendOK_Long  and macdBull
breakoutShort = ta.crossunder(close, prevLow  - atrVal*0.5) and trendOK_Short and macdBear

// 综合信号
longSignal  = entryLong  or breakoutLong
shortSignal = entryShort or breakoutShort

// ---------- 5. 绘图 ----------
plot(emaShort, "EMA20",  color=color.new(color.yellow, 0), linewidth=1)
plot(emaMid,   "EMA50",  color=color.new(color.orange, 0), linewidth=2)
plot(emaLong,  "EMA200", color=color.new(color.red, 0),    linewidth=3)

// 标记 swing
plotshape(not na(ph), title="Swing High", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, offset=-swingLen)
plotshape(not na(pl), title="Swing Low",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.tiny, offset=-swingLen)

// 入场信号 + 三阶梯目标
if longSignal
    sl  = low  - atrVal*atrSLMul
    tp1 = close + atrVal*atrTPMul1
    tp2 = close + atrVal*atrTPMul2
    tp3 = close + atrVal*atrTPMul3
    label.new(bar_index, low - atrVal*0.5,
        "▲ TREND LONG\nSL: " + str.tostring(sl, "#.##")
        + "\nT1: " + str.tostring(tp1, "#.##")
        + "\nT2: " + str.tostring(tp2, "#.##")
        + "\nT3: " + str.tostring(tp3, "#.##"),
        style=label.style_label_up, color=color.new(color.teal, 0), textcolor=color.white, size=size.small)
if shortSignal
    sl  = high + atrVal*atrSLMul
    tp1 = close - atrVal*atrTPMul1
    tp2 = close - atrVal*atrTPMul2
    tp3 = close - atrVal*atrTPMul3
    label.new(bar_index, high + atrVal*0.5,
        "▼ TREND SHORT\nSL: " + str.tostring(sl, "#.##")
        + "\nT1: " + str.tostring(tp1, "#.##")
        + "\nT2: " + str.tostring(tp2, "#.##")
        + "\nT3: " + str.tostring(tp3, "#.##"),
        style=label.style_label_down, color=color.new(color.maroon, 0), textcolor=color.white, size=size.small)

// 趋势背景
bgcolor(trendOK_Long  ? color.new(color.green, 94) : na, title="多头趋势底色")
bgcolor(trendOK_Short ? color.new(color.red,   94) : na, title="空头趋势底色")
bgcolor(overExtendedBull or overExtendedBear ? color.new(color.yellow, 92) : na, title="过度延伸警告")

// ---------- 6. 信息面板 ----------
var table info = table.new(position.top_right, 2, 8, border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "XAUUSD 趋势", text_color=color.white, bgcolor=color.new(color.black, 30))
    table.cell(info, 1, 0, str.tostring(close, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 30))

    table.cell(info, 0, 1, "本周期趋势", text_color=color.silver)
    table.cell(info, 1, 1, trendBull ? "多头" : trendBear ? "空头" : "震荡", text_color=trendBull ? color.green : trendBear ? color.red : color.yellow)

    table.cell(info, 0, 2, htfTF + " 趋势", text_color=color.silver)
    table.cell(info, 1, 2, htfBull ? "多头" : htfBear ? "空头" : "震荡", text_color=htfBull ? color.green : htfBear ? color.red : color.yellow)

    table.cell(info, 0, 3, "结构", text_color=color.silver)
    table.cell(info, 1, 3, structureBull ? "HH/HL" : structureBear ? "LH/LL" : "—", text_color=structureBull ? color.green : structureBear ? color.red : color.gray)

    table.cell(info, 0, 4, "MACD", text_color=color.silver)
    table.cell(info, 1, 4, macdBull ? "多动能" : macdBear ? "空动能" : "弱", text_color=macdBull ? color.green : macdBear ? color.red : color.gray)

    table.cell(info, 0, 5, "ATR", text_color=color.silver)
    table.cell(info, 1, 5, str.tostring(atrVal, "#.##"), text_color=color.white)

    table.cell(info, 0, 6, "过度延伸", text_color=color.silver)
    table.cell(info, 1, 6, overExtendedBull or overExtendedBear ? "是 → 暂停" : "否", text_color=overExtendedBull or overExtendedBear ? color.yellow : color.green)

    table.cell(info, 0, 7, "信号", text_color=color.silver)
    table.cell(info, 1, 7, longSignal ? "T-LONG" : shortSignal ? "T-SHORT" : "等待", text_color=longSignal ? color.green : shortSignal ? color.red : color.yellow)

// ---------- 7. 提醒 ----------
alertcondition(longSignal,  title="XAU 趋势多", message="XAUUSD 趋势多头入场 {{ticker}} @ {{close}}")
alertcondition(shortSignal, title="XAU 趋势空", message="XAUUSD 趋势空头入场 {{ticker}} @ {{close}}")
